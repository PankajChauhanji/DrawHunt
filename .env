# Copy to `.env` for local use, or set these in your host's dashboard.
# Never commit the real .env (it's in .gitignore).

# A long random string used to sign Flask sessions. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string

# Allowed Socket.IO origins. "*" is fine for testing. In production set this to
# your deployed origin, e.g. https://yourgame.onrender.com
CORS_ORIGINS=*

# Local dev only (the host provides PORT in production).
PORT=5000

# Set to 1 to enable Flask debug/reload locally. Leave 0 otherwise.
FLASK_DEBUG=0